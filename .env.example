# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Numeric chat ID of the owner (send /start to the bot to discover it)
TELEGRAM_CHAT_ID=123456789

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL, e.g. https://xyzxyz.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# service_role key (secret — never expose client-side)
SUPABASE_SERVICE_KEY=eyJ...

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → OAuth 2.0 client credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Long-lived refresh token obtained via get_google_token.py
GOOGLE_REFRESH_TOKEN=1//0g...

# ── GNews ─────────────────────────────────────────────────────────────────────
# Optional — brief degrades gracefully if absent
NEWS_API_KEY=your-gnews-api-key

# ── Locale / geography ────────────────────────────────────────────────────────
# IANA timezone string
TIMEZONE=America/New_York

# Coordinates for weather (defaults to Brooklyn, NY)
LATITUDE=40.6782
LONGITUDE=-73.9442

# Two-letter GNews country code
NEWS_COUNTRY=us

# ── Bot host ──────────────────────────────────────────────────────────────────
# Injected automatically by Railway/Render/Fly — set locally for testing
PORT=8080
